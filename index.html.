<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Прогулки по Петербургу</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: Arial, sans-serif; }
  #map { width: 100vw; height: 100vh; }
  #filter {
    position: absolute;
    top: 10px; left: 10px;
    z-index: 1000;
    background: white;
    padding: 10px 14px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    font-size: 14px;
  }
  #filter label { display: block; margin-bottom: 6px; font-weight: bold; }
  #filter select {
    width: 200px; padding: 4px 8px;
    border: 1px solid #ccc; border-radius: 4px;
    font-size: 14px; cursor: pointer;
  }
  .popup-title { font-weight: bold; font-size: 15px; margin-bottom: 4px; }
  .popup-date { color: #666; font-size: 13px; margin-bottom: 10px; }
  .popup-buttons { display: flex; gap: 6px; flex-wrap: wrap; }
  .popup-buttons a {
    padding: 5px 12px;
    border-radius: 5px;
    color: white;
    text-decoration: none;
    font-size: 13px;
    font-weight: bold;
  }
  .btn-vk { background: #4a76a8; }
  .btn-yt { background: #ff0000; }
  .btn-rt { background: #f60; }
  .btn-vk:hover { background: #3a5f8a; }
  .btn-yt:hover { background: #cc0000; }
  .btn-rt:hover { background: #d45500; }
</style>
</head>
<body>

<div id="filter">
  <label>Фильтр по улице:</label>
  <select id="streetFilter" onchange="applyFilter()">
    <option value="all">Все маршруты</option>
    <option value="Невский проспект">Невский проспект</option>
    <option value="Васильевский остров">Васильевский остров</option>
  </select>
</div>

<div id="map"></div>

<script>
// ======= ДАННЫЕ МАРШРУТОВ =======
const routes = [
  {
    id: 1,
    title: "Прогулка по Невскому проспекту",
    street: "Невский проспект",
    date: "15 января 2024",
    vk: "https://vk.com/video-000000_000000",
    youtube: "https://youtube.com/watch?v=XXXXXXXXXXX",
    rutube: "https://rutube.ru/video/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/",
    color: "#e74c3c",
    points: [
      [59.9343, 30.3351],
      [59.9331, 30.3467],
      [59.9322, 30.3580],
      [59.9311, 30.3701],
      [59.9300, 30.3821]
    ],
    markerIndex: 2
  },
  {
    id: 2,
    title: "Прогулка по Васильевскому острову",
    street: "Васильевский остров",
    date: "3 февраля 2024",
    vk: "https://vk.com/video-000000_000001",
    youtube: "https://youtube.com/watch?v=YYYYYYYYYYY",
    rutube: "https://rutube.ru/video/YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY/",
    color: "#e74c3c",
    points: [
      [59.9431, 30.2878],
      [59.9410, 30.2790],
      [59.9388, 30.2701],
      [59.9366, 30.2612],
      [59.9344, 30.2523]
    ],
    markerIndex: 2
  }
];

// ======= ИНИЦИАЛИЗАЦИЯ КАРТЫ =======
const map = L.map('map').setView([59.9343, 30.3351], 13);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© OpenStreetMap contributors',
  maxZoom: 19
}).addTo(map);

// ======= СОЗДАНИЕ МАРКЕРОВ И ЛИНИЙ =======
const layers = [];

routes.forEach(route => {
  const group = L.layerGroup();

  // Пунктирная линия (скрытая по умолчанию)
  const line = L.polyline(route.points, {
    color: route.color,
    weight: 3,
    dashArray: '8, 6',
    opacity: 0
  }).addTo(group);

  // Маркер в центре маршрута
  const center = route.points[route.markerIndex];
  const marker = L.marker(center).addTo(group);

  // Попап
  const popupContent = `
    <div class="popup-title">${route.title}</div>
    <div class="popup-date">📅 ${route.date}</div>
    <div class="popup-buttons">
      <a href="${route.vk}" target="_blank" class="btn-vk">ВКонтакте</a>
      <a href="${route.youtube}" target="_blank" class="btn-yt">YouTube</a>
      <a href="${route.rutube}" target="_blank" class="btn-rt">RuTube</a>
    </div>
  `;
  marker.bindPopup(popupContent, { maxWidth: 280 });

  // Показывать линию при наведении на маркер
  marker.on('mouseover', function() {
    line.setStyle({ opacity: 1 });
  });
  marker.on('mouseout', function() {
    if (!marker.isPopupOpen()) {
      line.setStyle({ opacity: 0 });
    }
  });
  marker.on('popupopen', function() {
    line.setStyle({ opacity: 1 });
  });
  marker.on('popupclose', function() {
    line.setStyle({ opacity: 0 });
  });

  group.addTo(map);
  layers.push({ route, group });
});

// ======= ФИЛЬТР ПО УЛИЦЕ =======
function applyFilter() {
  const selected = document.getElementById('streetFilter').value;
  layers.forEach(({ route, group }) => {
    if (selected === 'all' || route.street === selected) {
      map.addLayer(group);
    } else {
      map.removeLayer(group);
    }
  });
}
</script>

</body>
</html>
